<?xml version="1.0"?>
<ruleset name="WPVDB Coding Standards">
    <description>WordPress/VIP coding standards for WPVDB.</description>

    <file>includes</file>
    <file>wpvdb.php</file>
    <file>admin</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>tests/benchmarks/data/*</exclude-pattern>

    <rule ref="WordPress-VIP-Go" />
    <rule ref="WordPress">
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
    </rule>
</ruleset>
